{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter (Edge)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "edge"
            ]
        },
        {
            "name": "Flutter (Web Server)",
            "type": "dart",
